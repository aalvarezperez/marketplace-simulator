group_by(listing) %>%
summarise(
n_views = sum(view)
)
df_listings
df_listings <- df_listings %>%
group_by(entity) %>%
summarise(
n_views = sum(view)
)
df_listings <- df_listings %>%
group_by(entity) %>%
summarise(
n_views = sum(views)
)
df_listings
df_listings <- read_csv("listings_views.csv")
